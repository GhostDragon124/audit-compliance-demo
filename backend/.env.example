LLM_BASE_URL=http://127.0.0.1:8083/v1
LLM_API_KEY=
LLM_MODEL=qwen3.6-35b-a3b-fp8
LLM_MODE=mock
LLM_MAX_PROMPT_CHARS=24000

# OCR_PROVIDER supports paddleocr, tesseract, or disabled.
# paddleocr is attempted first by default, then tesseract, then disabled.
OCR_PROVIDER=paddleocr
OCR_DEVICE=cpu
OCR_LANG=ch
OCR_ENABLE=true

# Embedding/vector index configuration.
# EMBEDDING_PROVIDER supports random or openai_compatible.
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_MODEL=/models
EMBEDDING_BASE_URL=http://127.0.0.1:8085/v1
CHROMA_PERSIST_DIR=../data/indexes/chroma/regulations
CHROMA_COLLECTION_NAME=regulations
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# RAG mode: "disabled" skips retrieval, "required" uses real embedding + ChromaDB.
# When required, retrieval failure raises a controlled error (no silent fallback).
RAG_MODE=disabled
RAG_TOP_K=5

# Upload guardrails.
MAX_FILE_SIZE_MB=50
MAX_TOTAL_UPLOAD_MB=100
MAX_FILES_PER_REQUEST=10
PDF_MAX_PAGES=100
IMAGE_MAX_PIXELS=50000000
UPLOAD_CLEANUP=true
